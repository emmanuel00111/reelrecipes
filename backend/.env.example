# ── OpenAI ──────────────────────────────────
# Used for recipe extraction (claude.js) and Whisper transcription (transcript.js)
OPENAI_API_KEY=

# ── Supabase ─────────────────────────────────
# Project URL from: Supabase dashboard → Settings → API
SUPABASE_URL=

# Service role key (bypasses RLS) from: Supabase dashboard → Settings → API → service_role
SUPABASE_SERVICE_KEY=

# ── Server ───────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
